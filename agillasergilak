-- ==============================================
-- GLITCH TEXT EFFECT
-- ==============================================
local function addGlitchEffect(textLabel)
    local originalText = textLabel.Text
    local glitchChars = {"0", "1", "_", "|", "/", "\\", "#", "$", "%", "&", "?", "!", "@"}
    
    textLabel:GetPropertyChangedSignal("Text"):Connect(function()
        originalText = textLabel.Text
    end)
    
    task.spawn(function()
        while textLabel and textLabel.Parent do
            task.wait(math.random(3, 8))
            if textLabel and textLabel.Parent then
                local glitched = ""
                for i = 1, #originalText do
                    if math.random() < 0.1 then
                        glitched = glitched .. glitchChars[math.random(#glitchChars)]
                    else
                        glitched = glitched .. string.sub(originalText, i, i)
                    end
                end
                textLabel.Text = glitched
                task.wait(0.05)
                if textLabel and textLabel.Parent then
                    textLabel.Text = originalText
                end
            end
        end
    end)
end

