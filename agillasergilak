local function createDotEffect(parent, dotTable)
    local container = Instance.new("Frame", parent)
    container.Name = "MatrixRain"
    container.Size = UDim2.new(1, 0, 1, 0)
    container.Position = UDim2.new(0, 0, 0, 0)
    container.BackgroundTransparency = 1
    container.ZIndex = 0
    container.ClipsDescendants = true
    
    for i = 1, 80 do
        local dot = Instance.new("TextLabel")
        dot.Size = UDim2.new(0, 10, 0, 14)
        dot.Position = UDim2.new(math.random(), 0, math.random(), 0)
        dot.BackgroundTransparency = 1
        dot.TextColor3 = GradientColors.NeonGreen
        dot.Text = string.char(math.random(48, 57))
        dot.Font = Enum.Font.Code
        dot.TextSize = 10
        dot.TextTransparency = math.random(30, 80) / 100
        dot.Parent = container
        dot.ZIndex = 0
        
        dot:SetAttribute("SpeedY", math.random() * 0.03 + 0.01)
        dot:SetAttribute("XPos", dot.Position.X.Scale)
        dot:SetAttribute("YPos", dot.Position.Y.Scale)
        
        table.insert(dotTable, dot)
    end
    
    return container
end

local function updateDots(dotTable, dt)
    for _, dot in pairs(dotTable) do
        local sy = dot:GetAttribute("SpeedY") or 0.015
        local newY = dot.Position.Y.Scale + sy * dt * 30
        
        if newY > 1 then
            newY = 0
            dot:SetAttribute("XPos", math.random())
            dot.Position = UDim2.new(dot:GetAttribute("XPos"), 0, newY, 0)
            dot.Text = string.char(math.random(48, 57))
        else
            dot.Position = UDim2.new(dot:GetAttribute("XPos"), 0, newY, 0)
        end
        
        dot.TextTransparency = math.sin(tick() * 3) * 0.15 + 0.35
    end
end

