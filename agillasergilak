local function toggleJacket()
    jacketActive = not jacketActive
    
    if jacketActive then
        local anim = Instance.new("Animation")
        anim.AnimationId = "rbxassetid://70883871260184"
        
        if humanoid then
            local success, track = pcall(function()
                return humanoid:LoadAnimation(anim)
            end)
            if success then
                jacketAnimTrack = track
                jacketAnimTrack.Looped = true
                jacketAnimTrack.Priority = Enum.AnimationPriority.Movement
                jacketAnimTrack:Play()
            end
        end
        ShowNotification("> BIG_JACKET.exe", "ACTIVATED", "success")
    else
        if jacketAnimTrack then
            pcall(function() jacketAnimTrack:Stop() end)
            jacketAnimTrack = nil
        end
        ShowNotification("> BIG_JACKET.exe", "DEACTIVATED", "warning")
    end
end

local function toggleSpin()
    spinActive = not spinActive
    
    if spinActive then
        if spinConnection then spinConnection:Disconnect() end
        spinConnection = RunService.Heartbeat:Connect(function(dt)
            if spinActive and hrp and hrp.Parent then
                local targetSpeed = spinSpeed * 15
                local currentSpeed = hrp.RotVelocity.Y
                local newSpeed = currentSpeed + (targetSpeed - currentSpeed) * 0.3
                hrp.RotVelocity = Vector3.new(0, newSpeed, 0)
            end
        end)
        ShowNotification("> SPIN_MODE.sys", "SPEED: " .. spinSpeed, "success")
    else
        if spinConnection then
            spinConnection:Disconnect()
            spinConnection = nil
        end
        if hrp and hrp.Parent then
            hrp.RotVelocity = Vector3.new(0, 0, 0)
        end
        ShowNotification("> SPIN_MODE.sys", "DEACTIVATED", "warning")
    end
end

local function toggleGlitch()
    glitchActive = not glitchActive
    
    if glitchActive then
        if glitchConnection then glitchConnection:Disconnect() end
        local lastTime = tick()
        glitchConnection = RunService.Heartbeat:Connect(function(dt)
            if glitchActive and hrp and hrp.Parent then
                local now = tick()
                local delta = math.min(now - lastTime, 0.033)
                lastTime = now
                
                local intensity = glitchIntensity
                local smooth = 0.85
                
                local targetVel = Vector3.new(
                    (math.random() * 2 - 1) * intensity * 80,
                    (math.random() * 2 - 1) * intensity * 50,
                    (math.random() * 2 - 1) * intensity * 80
                )
                local targetRot = Vector3.new(
                    (math.random() * 2 - 1) * intensity * 30,
                    (math.random() * 2 - 1) * intensity * 30,
                    (math.random() * 2 - 1) * intensity * 30
                )
                
                hrp.Velocity = hrp.Velocity:Lerp(targetVel, smooth)
                hrp.RotVelocity = hrp.RotVelocity:Lerp(targetRot, smooth)
            end
        end)
        ShowNotification("> GLITCH_MODE.hax", "INTENSITY: " .. string.format("%.1f", glitchIntensity), "success")
    else
        if glitchConnection then
            glitchConnection:Disconnect()
            glitchConnection = nil
        end
        if hrp and hrp.Parent then
            hrp.Velocity = Vector3.new(0, 0, 0)
            hrp.RotVelocity = Vector3.new(0, 0, 0)
        end
        ShowNotification("> GLITCH_MODE.hax", "DEACTIVATED", "warning")
    end
end

-- ==============================================
-- SPECTATE FUNCTIONS
-- ==============================================

local spectateWindow = nil
local spectating = false
local spectateTarget = nil
local spectateConnection = nil
local followActive = false
local followConnection = nil
local originalCameraSubject = nil
local selectedPlayer = nil

local function getTargetHead(targetPlayer)
    if not targetPlayer then return nil end
    local targetChar = targetPlayer.Character
    if not targetChar or not targetChar.Parent then return nil end
    return targetChar:FindFirstChild("Head")
end

local function getTargetHRP(targetPlayer)
    if not targetPlayer then return nil end
    local targetChar = targetPlayer.Character
    if not targetChar or not targetChar.Parent then return nil end
    return targetChar:FindFirstChild("HumanoidRootPart")
end

local function stopSpectate()
    if spectating then
        spectating = false
        if spectateConnection then
            spectateConnection:Disconnect()
            spectateConnection = nil
        end
        local ownChar = player.Character
        if ownChar then
            local ownHRP = ownChar:FindFirstChild("HumanoidRootPart")
            if ownHRP then
                Camera.CameraSubject = ownHRP
            end
        end
        Camera.CameraType = Enum.CameraType.Custom
        spectateTarget = nil
    end
end

local function stopFollow()
    if followActive then
        followActive = false
        if followConnection then
            followConnection:Disconnect()
            followConnection = nil
        end
    end
end

local function stopAllSpectate()
    stopSpectate()
    stopFollow()
    ShowNotification("> SPECTATE.sys", "ALL_STOPPED", "warning")
end

local function startSpectate(targetPlayer)
    if not targetPlayer then return end
    
    stopSpectate()
    
    local targetHead = getTargetHead(targetPlayer)
    if not targetHead then
        ShowNotification("> ERROR", "TARGET_LOST", "error")
        return
    end
    
    spectating = true
    spectateTarget = targetPlayer
    
    local ownChar = player.Character
    if ownChar then
        local ownHRP = ownChar:FindFirstChild("HumanoidRootPart")
        if ownHRP then
            originalCameraSubject = ownHRP
        end
    end
    
    Camera.CameraSubject = targetHead
    Camera.CameraType = Enum.CameraType.Attach
    
    spectateConnection = RunService.RenderStepped:Connect(function()
        if spectating and spectateTarget then
            local newHead = getTargetHead(spectateTarget)
            if newHead and newHead.Parent then
                Camera.CameraSubject = newHead
            else
                stopSpectate()
                ShowNotification("> ERROR", "TARGET_LOST", "error")
            end
        end
    end)
    
    ShowNotification("> SPECTATE.exe", "WATCHING: " .. targetPlayer.DisplayName, "success")
end

local function startFollow(targetPlayer)
    if not targetPlayer then return end
    
    stopFollow()
    
    local targetHRP = getTargetHRP(targetPlayer)
    if not targetHRP then
        ShowNotification("> ERROR", "FOLLOW_FAILED", "error")
        return
    end
    
    followActive = true
    
    followConnection = RunService.RenderStepped:Connect(function()
        if followActive and targetPlayer and targetPlayer.Character then
            local newHRP = getTargetHRP(targetPlayer)
            if newHRP and newHRP.Parent and hrp and hrp.Parent then
                local targetPos = newHRP.Position + Vector3.new(0, 2.5, 0)
                local currentRot = hrp.CFrame - hrp.Position
                local currentPos = hrp.Position
                local newPos = currentPos:Lerp(targetPos, 0.4)
                hrp.CFrame = CFrame.new(newPos) * currentRot
            else
                stopFollow()
                ShowNotification("> ERROR", "TARGET_LOST", "error")
            end
        end
    end)
    
    ShowNotification("> FOLLOW.sys", "FOLLOWING: " .. targetPlayer.DisplayName, "success")
end

local function teleportToPlayer(targetPlayer)
    if not targetPlayer then return end
    
    local targetHRP = getTargetHRP(targetPlayer)
    if not targetHRP then
        ShowNotification("> ERROR", "TELEPORT_FAILED", "error")
        return
    end
    
    if hrp and hrp.Parent then
        local targetPos = targetHRP.Position + Vector3.new(0, 3, 0)
        local currentRot = hrp.CFrame - hrp.Position
        hrp.CFrame = CFrame.new(targetPos) * currentRot
        ShowNotification("> TELEPORT.sys", "TO: " .. targetPlayer.DisplayName, "success")
    end
end

local function refreshPlayerList()
    local list = {}
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= player then
            table.insert(list, plr)
        end
    end
    return list
end

